// esp32/src/config.h
#ifndef CONFIG_H
#define CONFIG_H

// WiFi configuration
#define WIFI_SSID "your-ssid"
#define WIFI_PASS "your-password"

// Server configuration
#define SERVER_URL "http://192.168.1.100:8088"

// Firmware version (increment when uploading new firmware)
#define FIRMWARE_VERSION 1

// Hardware
#define LED_PIN 2

// BLE identifiers for the thermometer. Defaults match the ThermoPro TP25.
// Discover values for a different unit with: `make esp32-scan`.
#define BLE_NAME             "Thermopro"
#define BLE_SERVICE_UUID     "1086fff0-3343-4817-8bb2-b32206336ce8"
#define BLE_WRITE_CHAR_UUID  "1086fff1-3343-4817-8bb2-b32206336ce8"
#define BLE_NOTIFY_CHAR_UUID "1086fff2-3343-4817-8bb2-b32206336ce8"

#endif
